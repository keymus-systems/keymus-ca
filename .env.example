# Frontend Build Configuration
# Copy this file to .env and adjust values for your environment.

# Port the chat server listens on (used for localhost dev URL)
CHAT_PORT=3001

# Production chat server URL
# Leave blank to auto-derive from the browser's hostname via nginx proxy (/chat/).
# Set explicitly if your chat server is on a different domain.
# e.g. CHAT_PROD_URL=https://chat.example.com
CHAT_PROD_URL=
